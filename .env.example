# 로컬 개발용 — 실제 값은 GCP Secret Manager(api·worker) / Cloudflare 환경변수(프론트)
DATABASE_URL=postgresql+asyncpg://essesion:essesion@localhost:5432/essesion
SENTRY_DSN=
ENV=local

# Vertex AI (worker) — 로컬은 gcloud ADC를 사용한다.
GCP_PROJECT_ID=
VERTEX_AI_LOCATION=global

# 소셜 OAuth (비우면 해당 프로바이더 비활성)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# .p8 PEM 내용 — 개행은 \n 이스케이프로 한 줄에 (dotenv가 복원)
APPLE_PRIVATE_KEY=

# Cloud Tasks 없이 finalize를 요청 내에서 워커로 직접 실행 — 로컬 필수 (없으면 finalize가 queued로 방치됨)
WORKER_FINALIZE_INLINE=true

# 무과금 디자인 아이디어 helper의 인증 사용자별 process-local 보조 제한
# 프로덕션은 Cloudflare `/design/ideas` IP rate limit을 별도로 둔다.
DESIGN_IDEAS_RATE_LIMIT_ATTEMPTS=6
DESIGN_IDEAS_RATE_LIMIT_WINDOW_SECONDS=60

# 로컬 파일 스토리지 — docker compose의 fake-gcs-server (local/test 전용, 서명 생략)
# 비우면 업로드·산출물 저장이 DryRun(no-op)으로 동작한다.
GCS_EMULATOR_HOST=http://localhost:4443
GCS_UPLOAD_BUCKET=dev-uploads
GCS_ASSETS_BUCKET=dev-assets
GCS_BUCKET=dev-assets
