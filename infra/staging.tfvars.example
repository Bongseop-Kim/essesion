# cp staging.tfvars.example staging.tfvars 후 채우기 (tfvars는 gitignore)
project_id        = "essesion-staging"
billing_account   = "XXXXXX-XXXXXX-XXXXXX"
alert_email       = "biblecookie@naver.com"
public_api_origin = "https://api.essesion.shop"

# 비시크릿 운영 env — 첫 apply부터 공개 Cloudflare 도메인으로 설정 (시크릿은 gcloud 주입, README)
# 도메인 확정: essesion.shop. 일반 API에 run.app URL을 사용하거나 외부 콘솔에 등록하지 않는다.
