{
  "name": "essesion",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check . && node scripts/check-harness.mjs",
    "format": "biome format --write .",
    "codegen": "uv run python apps/api/scripts/export_openapi.py && pnpm --filter @essesion/api-client generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "turbo": "^2.10.3"
  }
}
